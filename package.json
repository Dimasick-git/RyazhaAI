{
  "name": "ryazha-ai",
  "private": true,
  "version": "2.0.0",
  "description": "RYAZHA AI - Умный помощник для Nintendo Switch с CFW",
  "author": "Dimasick-git & Ryazhenka-Helper-01",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "build-release": "node build-release.js",
    "build-nro": "cd release && chmod +x build-nro.sh && ./build-nro.sh",
    "package": "npm run build-release && npm run build-nro && cd release && powershell -Command \"Compress-Archive -Path dist,switch,RyazhaAI.nro,README.md -DestinationPath RyazhaAI-release.zip -Force\"",
    "release": "npm run package"
  },
  "homepage": "https://dimasick-git.github.io/RyazhaAI",
  "dependencies": {
    "axios": "^1.6.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.16",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^8.0.11"
  }
}
