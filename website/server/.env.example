# ─────────────────────────────────────────────────────────────────────────────
# RYAZHA AI — Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Server port
PORT=3001

# ── Primary AI Provider: Anthropic Claude (recommended) ──────────────────────
# Get your key at https://console.anthropic.com/
# When set, Claude claude-haiku-4-5 is used as the main AI with ChatAnywhere as fallback.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Fallback AI Provider: ChatAnywhere (OpenAI-compatible) ───────────────────
# Get a free key from https://github.com/chatanywhere/GPT_API_free
# Required if ANTHROPIC_API_KEY is not set.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: HTTP/HTTPS Proxy ────────────────────────────────────────────────
# USE_PROXY=false
# PROXY_URL=http://127.0.0.1:7890
